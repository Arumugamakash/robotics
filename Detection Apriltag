import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image
from std_msgs.msg import String
from cv_bridge import CvBridge

import cv2
import numpy as np
from pupil_apriltags import Detector


class AprilTagDetectorNode(Node):

    def __init__(self):
        super().__init__('apriltag_detector_node')

        # 🔹 Subscriber (camera)
        self.subscription = self.create_subscription(
            Image,
            '/camera/image',  
            self.image_callback,
            10
        )

        # 🔹 Publisher
        self.publisher = self.create_publisher(String, '/detections', 10)

        self.bridge = CvBridge()

        # 🔹 AprilTag detector
        self.detector = Detector(
            families='tag36h11',
            nthreads=4,
            quad_decimate=1.0,
            quad_sigma=0.0,
            refine_edges=1
        )

        # 🔹 Camera intrinsics (⚠️ MUST change with your calibration)
        self.fx = 600
        self.fy = 600
        self.cx = 320
        self.cy = 240

        # Tag size (meters)
        self.tag_size = 0.16

        self.get_logger().info("AprilTag Detector Node Started")

    def image_callback(self, msg):
        # Convert ROS Image → OpenCV
        frame = self.bridge.imgmsg_to_cv2(msg, desired_encoding='bgr8')
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

        # Detect tags
        detections = self.detector.detect(
            gray,
            estimate_tag_pose=True,
            camera_params=(self.fx, self.fy, self.cx, self.cy),
            tag_size=self.tag_size
        )

        for det in detections:
            tag_id = det.tag_id

            # Pose (camera frame)
            pose_t = det.pose_t  # translation vector

            x = pose_t[0][0]
            y = pose_t[1][0]
            z = pose_t[2][0]

            # Publish
            msg_out = String()
            msg_out.data = f"{tag_id},{x},{y},{z}"
            self.publisher.publish(msg_out)

            self.get_logger().info(f"Detected ID:{tag_id} Pose:{x:.2f},{y:.2f},{z:.2f}")


def main():
    rclpy.init()
    node = AprilTagDetectorNode()
    rclpy.spin(node)
    rclpy.shutdown()
