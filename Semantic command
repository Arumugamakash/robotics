import rclpy
from rclpy.node import Node
from std_msgs.msg import String


class SemanticCommand(Node):

    def __init__(self):   # ✅ FIXED
        super().__init__('semantic_command')

        self.pub = self.create_publisher(String, '/semantic_goal', 10)

        self.timer = self.create_timer(3.0, self.get_input)

    def get_input(self):
        cmd = input("Enter goal (crate/pallet/box): ")
        self.pub.publish(String(data=cmd))


def main():
    rclpy.init()
    node = SemanticCommand()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()
