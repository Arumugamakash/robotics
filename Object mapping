import rclpy
from rclpy.node import Node
from std_msgs.msg import String
from geometry_msgs.msg import PoseStamped
import tf2_ros
import tf2_geometry_msgs
from rclpy.duration import Duration
from rclpy.time import Time


class ObjectMapper(Node):
    def __init__(self):
        super().__init__('object_mapper')
        self.sub = self.create_subscription(
            String,
            '/detections',
            self.callback,
            10
        )
        self.pub = self.create_publisher(String, '/objects', 10)
        self.tf_buffer = tf2_ros.Buffer()
        self.tf_listener = tf2_ros.TransformListener(self.tf_buffer, self)
        self.marker_map = {
            0: "crate",
            1: "pallet",
            2: "box"
        }
        self.get_logger().info("Object Mapper with TF2 started")

    def callback(self, msg):
        try:
            tag_id, x, y, z = msg.data.split(',')
            tag_id = int(tag_id)
            x, y, z = float(x), float(y), float(z)

            obj_type = self.marker_map.get(tag_id, "unknown")

            pose_cam = PoseStamped()
            pose_cam.header.frame_id = "camera_link"
            # ✅ FIX: Use Time(0) = "latest available" instead of now()
            pose_cam.header.stamp = Time(seconds=0).to_msg()
            pose_cam.pose.position.x = x
            pose_cam.pose.position.y = y
            pose_cam.pose.position.z = z
            pose_cam.pose.orientation.w = 1.0

            # ✅ FIX: can_transform also uses Time(0)
            if not self.tf_buffer.can_transform(
                "map",
                "camera_link",
                Time(seconds=0),
                timeout=Duration(seconds=1.0)
            ):
                self.get_logger().warn("TF not ready: camera_link → map")
                return

            # ✅ FIX: transform with Time(0) — no extrapolation needed
            pose_map = self.tf_buffer.transform(
                pose_cam,
                "map",
                timeout=Duration(seconds=1.0)
            )

            map_x = pose_map.pose.position.x
            map_y = pose_map.pose.position.y

            out = f"{obj_type},{map_x:.4f},{map_y:.4f}"
            self.pub.publish(String(data=out))
            self.get_logger().info(
                f"{obj_type} @ tag_id={tag_id} → Map: ({map_x:.2f}, {map_y:.2f})"
            )

        except Exception as e:
            self.get_logger().warn(f"TF failed: {e}")


def main():
    rclpy.init()
    node = ObjectMapper()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()




import rclpy
from rclpy.node import Node
from std_msgs.msg import String
from geometry_msgs.msg import PoseStamped
import tf2_ros
import tf2_geometry_msgs
from rclpy.duration import Duration
from rclpy.time import Time


class ObjectMapper(Node):
    def __init__(self):
        super().__init__('object_mapper')
        
        self.sub = self.create_subscription(
            String,
            '/detections',
            self.callback,
            10
        )
        
        self.pub = self.create_publisher(String, '/objects', 10)
        
        self.tf_buffer = tf2_ros.Buffer()
        self.tf_listener = tf2_ros.TransformListener(self.tf_buffer, self)
        
        self.marker_map = {
            0: "crate",
            1: "pallet",
            2: "box"
        }
        
        self.get_logger().info("Object Mapper with TF2 started")

    def callback(self, msg):
        try:
            tag_id, x, y, z = msg.data.split(',')
            tag_id = int(tag_id)
            x, y, z = float(x), float(y), float(z)

            obj_type = self.marker_map.get(tag_id, "unknown")

            pose_cam = PoseStamped()
            pose_cam.header.frame_id = "camera_link"
            pose_cam.header.stamp = Time(seconds=0).to_msg()

            # ✅ Axis remap:
            # Camera frame: z = forward (depth), x = left/right, y = up/down
            # Robot/Map frame: x = forward, y = left/right, z = up
            pose_cam.pose.position.x = z    # camera depth → forward in map
            pose_cam.pose.position.y = -x   # camera left/right → lateral in map
            pose_cam.pose.position.z = y    # camera up/down → height (not used in 2D)
            pose_cam.pose.orientation.w = 1.0

            # Check TF availability
            if not self.tf_buffer.can_transform(
                "map",
                "camera_link",
                Time(seconds=0),
                timeout=Duration(seconds=1.0)
            ):
                self.get_logger().warn("TF not ready: camera_link → map")
                return

            # Transform pose from camera_link to map frame
            pose_map = self.tf_buffer.transform(
                pose_cam,
                "map",
                timeout=Duration(seconds=1.0)
            )

            map_x = pose_map.pose.position.x
            map_y = pose_map.pose.position.y

            out = f"{obj_type},{map_x:.4f},{map_y:.4f}"
            self.pub.publish(String(data=out))

            self.get_logger().info(
                f"{obj_type} @ tag_id={tag_id} → Map: ({map_x:.2f}, {map_y:.2f})"
            )

        except ValueError as e:
            self.get_logger().warn(f"Message parse error: {e}")
        except Exception as e:
            self.get_logger().warn(f"TF failed: {e}")


def main():
    rclpy.init()
    node = ObjectMapper()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
