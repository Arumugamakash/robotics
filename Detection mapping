import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image
from std_msgs.msg import String
from geometry_msgs.msg import PoseStamped
from cv_bridge import CvBridge
import tf2_ros
import tf2_geometry_msgs  # MUST import — registers PoseStamped with tf2
from rclpy.duration import Duration

import cv2
from pupil_apriltags import Detector


class AprilTagMapperNode(Node):

    def __init__(self):
        super().__init__('apriltag_mapper_node')

        # Subscriber: raw camera images
        self.subscription = self.create_subscription(
            Image,
            '/camera/image',
            self.image_callback,
            10
        )

        # Publisher: mapped objects
        self.publisher = self.create_publisher(String, '/objects', 10)

        self.bridge = CvBridge()

        # AprilTag detector
        self.detector = Detector(
            families='tag36h11',
            nthreads=4,
            quad_decimate=1.0,
            quad_sigma=0.0,
            refine_edges=1
        )

        # Camera intrinsics — update with your calibration values
        self.fx = 600.12
        self.fy = 601.34
        self.cx = 319.87
        self.cy = 241.20

        # Physical tag size in meters
        self.tag_size = 0.16

        # Tag ID → object name mapping
        self.marker_map = {
            0: "crate",
            1: "pallet",
            2: "box"
        }

        # TF2 setup
        self.tf_buffer = tf2_ros.Buffer()
        self.tf_listener = tf2_ros.TransformListener(self.tf_buffer, self)

        self.get_logger().info("AprilTag Mapper Node Started")

    def image_callback(self, msg):
        # Convert ROS Image → OpenCV grayscale
        frame = self.bridge.imgmsg_to_cv2(msg, desired_encoding='bgr8')
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

        # Detect AprilTags with pose estimation
        detections = self.detector.detect(
            gray,
            estimate_tag_pose=True,
            camera_params=(self.fx, self.fy, self.cx, self.cy),
            tag_size=self.tag_size
        )

        for det in detections:
            tag_id = det.tag_id
            pose_t = det.pose_t  # translation in camera frame

            cam_x = pose_t[0][0]
            cam_y = pose_t[1][0]
            cam_z = pose_t[2][0]

            obj_type = self.marker_map.get(tag_id, "unknown")

            # Build PoseStamped in camera_link frame
            # Axis remap:
            #   Camera: z=forward, x=left/right, y=up/down
            #   Map:    x=forward, y=left/right, z=up
            pose_cam = PoseStamped()
            pose_cam.header.frame_id = "camera_link"
            pose_cam.header.stamp = rclpy.time.Time().to_msg()  # Time(0) = use latest TF
            pose_cam.pose.position.x = cam_z    # depth → forward
            pose_cam.pose.position.y = -cam_x   # lateral
            pose_cam.pose.position.z = cam_y    # height
            pose_cam.pose.orientation.w = 1.0

            # Check TF availability before transforming
            if not self.tf_buffer.can_transform(
                "map",
                "camera_link",
                rclpy.time.Time(),
                timeout=Duration(seconds=0.5)
            ):
                self.get_logger().warn(
                    "TF not ready: camera_link → map",
                    throttle_duration_sec=2.0
                )
                continue

            try:
                pose_map = self.tf_buffer.transform(
                    pose_cam,
                    "map",
                    timeout=Duration(seconds=0.5)
                )
            except Exception as e:
                self.get_logger().warn(
                    f"TF transform failed: {e}",
                    throttle_duration_sec=2.0
                )
                continue

            map_x = pose_map.pose.position.x
            map_y = pose_map.pose.position.y

            out = String()
            out.data = f"{obj_type},{map_x:.4f},{map_y:.4f}"
            self.publisher.publish(out)

            self.get_logger().info(
                f"[ID:{tag_id}] {obj_type} → Map: ({map_x:.2f}, {map_y:.2f})"
            )


def main():
    rclpy.init()
    node = AprilTagMapperNode()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
